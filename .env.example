# Copia este archivo como .env.local (desarrollo) o define estas variables en
# Coolify (producción). La landing arranca sin ellas, en modo de respaldo.

# --- Base de datos (la administra el panel) ---
# En Coolify usar el host UUID del contenedor, no el nombre bonito.
DATABASE_URL=postgres://usuario:contrasena@host:5432/basededatos

# --- Regeneración desde el panel ---
# Debe ser IDÉNTICO al REVALIDATE_TOKEN del panel.
REVALIDATE_TOKEN=pon-aqui-un-secreto-largo

# --- Aviso por correo de los mensajes de contacto (SMTP de Zoho) ---
# Sin estas, el mensaje se guarda igual pero no se envía correo.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=contacto@serviciosydesarrollojc.com
# Contraseña de APLICACIÓN de Zoho (Settings → Security → App Passwords),
# NO la contraseña normal de la cuenta.
SMTP_PASS=xxxxxxxxxxxx
CONTACT_EMAIL_FROM=contacto@serviciosydesarrollojc.com
# Destinos del aviso, separados por coma.
CONTACT_EMAIL_TO=contacto@serviciosydesarrollojc.com,fellmannjosue@gmail.com

# Copia este archivo como .env.local y ajusta los valores.
# La landing LEE los proyectos de esta base y se regenera cuando el panel avisa.

# Conexión a PostgreSQL (el mismo que usa el panel de administración).
DATABASE_URL=postgres://usuario:contrasena@host:5432/jc_panel

# Contraseña compartida con el panel: protege el endpoint POST /api/revalidate.
# Debe ser EXACTAMENTE la misma en las dos aplicaciones.
REVALIDATE_TOKEN=pon-aqui-un-secreto-largo

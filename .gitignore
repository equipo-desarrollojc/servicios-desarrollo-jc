# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# la plantilla sin secretos sí se versiona
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mensajes del formulario de contacto (persisten solo en el volumen)
/data

# configuración personal de Claude Code (la memoria de equipo va en AGENTS.md)
.claude/settings.local.json
